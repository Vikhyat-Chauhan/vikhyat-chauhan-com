---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  publishedTime?: string;
  keywords?: string;
  /** Optional JSON-LD object emitted in <head> (e.g. BlogPosting for articles). */
  schema?: Record<string, unknown>;
}

const {
  title = 'Vikhyat Chauhan — Production AI Engineer',
  description = 'Production AI engineer shipping TensorRT inference on regulated hardware, ROS 2 simulation stacks, LangGraph agentic systems, and RAG pipelines. M.S. Computer Engineering, Virginia Tech. ex-GE HealthCare.',
  ogImage = '/og-image.png',
  ogType = 'website',
  publishedTime,
  keywords,
  schema,
} = Astro.props;

const siteUrl = Astro.site ?? new URL('https://vikhyatchauhan.com');
const canonical = new URL(Astro.url.pathname, siteUrl).toString();
const ogImageUrl = new URL(ogImage, siteUrl).toString();
const isHome = Astro.url.pathname === '/' || Astro.url.pathname === '';

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Vikhyat Chauhan',
  url: siteUrl.toString(),
  image: new URL('/vikhyatchauhanimage.jpg', siteUrl).toString(),
  jobTitle: 'Production AI Engineer',
  description,
  email: 'mailto:vikhyat.chauhan@gmail.com',
  telephone: '+1-201-616-6373',
  sameAs: [
    'https://github.com/Vikhyat-Chauhan',
    'https://www.linkedin.com/in/vikhyat-chauhan/',
  ],
  alumniOf: [
    {
      '@type': 'CollegeOrUniversity',
      name: 'Virginia Polytechnic Institute and State University',
    },
    {
      '@type': 'CollegeOrUniversity',
      name: 'Uttarakhand Technical University',
    },
  ],
  worksFor: {
    '@type': 'CollegeOrUniversity',
    name: 'Virginia Polytechnic Institute and State University',
  },
  knowsAbout: [
    'Large Language Models',
    'Retrieval-Augmented Generation',
    'TensorRT',
    'TensorRT Optimization',
    'CUDA',
    'MLOps',
    'LangGraph',
    'Agentic Systems',
    'Multi-Agent Systems',
    'ROS 2',
    'Medical Imaging AI',
  ],
};
---

<!doctype html>
<html lang="en" class="bg-stone-50 text-zinc-900">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {keywords && <meta name="keywords" content={keywords} />}
    <meta name="author" content="Vikhyat Chauhan" />
    <meta name="theme-color" content="#fafaf9" id="theme-color-meta" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="me" href="https://github.com/Vikhyat-Chauhan" />
    <link rel="me" href="https://www.linkedin.com/in/vikhyat-chauhan/" />
    <link rel="me" href="mailto:vikhyat.chauhan@gmail.com" />
    <link rel="preconnect" href="https://rsms.me/" />
    <link rel="preload" as="style" href="https://rsms.me/inter/inter.css" />
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />

    <!-- Apply persisted theme before paint to avoid flash -->
    <script is:inline>
      (() => {
        try {
          const stored = localStorage.getItem('theme');
          const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          const theme = stored || (prefersDark ? 'dark' : 'light');
          if (theme === 'dark') document.documentElement.classList.add('dark');
          const meta = document.getElementById('theme-color-meta');
          if (meta) meta.setAttribute('content', theme === 'dark' ? '#0a0a0a' : '#fafaf9');
        } catch {}
      })();
    </script>

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    {ogType === 'article' && publishedTime && (
      <meta property="article:published_time" content={publishedTime} />
    )}
    {ogType === 'article' && <meta property="article:author" content="Vikhyat Chauhan" />}
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Vikhyat Chauhan — Production AI Engineer" />
    <meta property="og:site_name" content="Vikhyat Chauhan" />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <title>{title}</title>

    {isHome && (
      <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
    )}
    {schema && (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    )}

    <style is:global>
      /* Scroll-reveal */
      [data-animate] {
        opacity: 0;
        transform: translateY(12px);
        transition:
          opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1),
          transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
        transition-delay: var(--delay, 0ms);
        will-change: opacity, transform;
      }
      [data-animate].is-visible {
        opacity: 1;
        transform: none;
      }

      /* Project card hover-lift */
      .project-card {
        transition:
          transform 0.3s cubic-bezier(0.22, 1, 0.36, 1),
          background-color 0.3s ease;
        border-radius: 12px;
        padding: 1.5rem 0.5rem;
        margin: 0 -0.5rem;
      }
      @media (min-width: 640px) {
        .project-card {
          padding: 2rem 0.75rem;
          margin: 0 -0.75rem;
        }
      }
      .project-card:hover {
        transform: translateY(-3px);
        background-color: rgba(255, 255, 255, 0.55);
      }

      /* Subtle pulse glow on hero status dot's outer ring (already pings) */
      .gradient-shift {
        background-size: 200% 100%;
        animation: gradient-shift 8s ease-in-out infinite;
      }
      @keyframes gradient-shift {
        0%, 100% { background-position: 0% 50%; }
        50% { background-position: 100% 50%; }
      }

      /* Scroll progress: gradient grows from 0 → 100% of viewport width */
      #scroll-progress {
        transform-origin: left center;
        transform: scaleX(0);
        transition: transform 0.08s linear;
      }

      @media (prefers-reduced-motion: reduce) {
        [data-animate],
        [data-animate].is-visible {
          opacity: 1 !important;
          transform: none !important;
          transition: none !important;
        }
        .project-card:hover { transform: none; }
        .gradient-shift { animation: none; }
        #scroll-progress { transition: none; }
      }
    </style>
  </head>
  <body class="min-h-screen font-sans antialiased">
    <div
      aria-hidden="true"
      class="fixed inset-x-0 top-0 z-[60] h-[3px] bg-zinc-200/40"
    >
      <div
        id="scroll-progress"
        class="gradient-shift h-full w-full bg-gradient-to-r from-orange-500 via-amber-400 via-30% via-sky-500 via-60% via-violet-500 via-85% to-emerald-500"
      ></div>
    </div>

    <button
      id="theme-toggle"
      type="button"
      aria-label="Toggle dark mode"
      title="Toggle dark mode"
      class="fixed bottom-4 left-4 z-40 inline-flex h-9 w-9 items-center justify-center rounded-full border border-zinc-300 bg-white text-zinc-700 shadow-md shadow-zinc-900/10 transition hover:border-zinc-400 hover:text-zinc-900 sm:bottom-6 sm:left-6"
    >
      <svg class="icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
      </svg>
      <svg class="icon-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="4" />
        <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
      </svg>
    </button>

    <script is:inline>
      (() => {
        const btn = document.getElementById('theme-toggle');
        if (!btn) return;
        const meta = document.getElementById('theme-color-meta');
        btn.addEventListener('click', () => {
          const isDark = document.documentElement.classList.toggle('dark');
          try { localStorage.setItem('theme', isDark ? 'dark' : 'light'); } catch {}
          if (meta) meta.setAttribute('content', isDark ? '#0a0a0a' : '#fafaf9');
        });
      })();
    </script>

    <slot />

    <script>
      import {
        trackPageview,
        trackTabClick,
        trackOutbound,
        trackResumeDownload,
        trackTimeOnSite,
      } from '../lib/track';

      const TAB_LABELS: Record<string, string> = {
        projects: 'Projects',
        experience: 'Experience',
        blog: 'Blog',
        writing: 'Writing',
        education: 'Education',
        publications: 'Publications',
        awards: 'Awards',
        contact: 'Contact',
        top: 'Home',
      };

      // 1) Pageview on load
      trackPageview();

      // 1a) Scroll progress bar (skip if user prefers reduced motion)
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const progressBar = document.getElementById('scroll-progress');
      if (progressBar && !reduceMotion) {
        let ticking = false;
        const updateProgress = () => {
          const docHeight = document.documentElement.scrollHeight - window.innerHeight;
          const pct = docHeight > 0 ? Math.min(window.scrollY / docHeight, 1) : 0;
          progressBar.style.transform = `scaleX(${pct})`;
          ticking = false;
        };
        window.addEventListener(
          'scroll',
          () => {
            if (!ticking) {
              requestAnimationFrame(updateProgress);
              ticking = true;
            }
          },
          { passive: true },
        );
        updateProgress();
      } else if (progressBar) {
        progressBar.style.transform = 'scaleX(1)';
      }

      // 1b) Scroll-reveal — fade-up via IntersectionObserver
      const revealEls = document.querySelectorAll<HTMLElement>('[data-animate]');
      if ('IntersectionObserver' in window && revealEls.length > 0) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                io.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.08, rootMargin: '0px 0px -40px 0px' },
        );
        revealEls.forEach((el) => io.observe(el));
      } else {
        revealEls.forEach((el) => el.classList.add('is-visible'));
      }

      // 2) Time on site — accumulate active seconds, flush on hide/unload
      let activeSince = Date.now();
      let accumulated = 0;
      let flushed = false;

      function flushTime() {
        if (flushed) return;
        const now = Date.now();
        if (document.visibilityState === 'visible') {
          accumulated += Math.round((now - activeSince) / 1000);
        }
        if (accumulated >= 1) {
          trackTimeOnSite(accumulated);
          flushed = true;
        }
      }

      document.addEventListener('visibilitychange', () => {
        const now = Date.now();
        if (document.visibilityState === 'hidden') {
          accumulated += Math.round((now - activeSince) / 1000);
          if (accumulated >= 1) {
            trackTimeOnSite(accumulated);
            accumulated = 0;
            flushed = true;
          }
        } else {
          activeSince = now;
          flushed = false;
        }
      });
      window.addEventListener('pagehide', flushTime);
      window.addEventListener('beforeunload', flushTime);

      // 3) Delegated click handler — outbound / resume / tab
      document.addEventListener('click', (e) => {
        const target = e.target as HTMLElement | null;
        const a = target?.closest('a') as HTMLAnchorElement | null;
        if (!a) return;
        const href = a.getAttribute('href');
        if (!href) return;

        if (a.hasAttribute('download')) {
          trackResumeDownload();
          return;
        }

        // In-page anchor → tab_click
        if (href.startsWith('#')) {
          const id = href.slice(1);
          trackTabClick(TAB_LABELS[id] || id);
          return;
        }
        // Cross-page anchor like /#projects (from sub-pages)
        if (href.startsWith('/#')) {
          const id = href.slice(2);
          trackTabClick(TAB_LABELS[id] || id);
          return;
        }

        // Outbound — anything not same-origin and not a special scheme
        if (href.startsWith('http://') || href.startsWith('https://')) {
          try {
            const url = new URL(href);
            if (url.hostname !== location.hostname) {
              trackOutbound(href);
            }
          } catch {
            /* ignore */
          }
        } else if (href.startsWith('mailto:') || href.startsWith('tel:')) {
          trackOutbound(href);
        }
      });
    </script>
  </body>
</html>
